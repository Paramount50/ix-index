# Nix
.jupyter/
.ipynb_checkpoints/
result
result-*
.direnv/

# ix CLI local state
.ix/

# Build outputs
.gradle/
build/
target/
target-*/
buck-out/
dist/

# Node / pnpm
node_modules/
.pnpm-store/

# SvelteKit / Vite
.svelte-kit/
.vite/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
*.egg-info/
# Compiled PyO3 extension modules dropped in-tree by `maturin develop`
*.abi3.so
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.basedpyright/

# Terraform / OpenTofu local state
.terraform/
*.tfstate
*.tfstate.*

# Local caches and scratch
.tmp/
.hegel/
.worktrees/

# Editors
.idea/

# Claude Code per-machine overrides
.claude/settings.local.json
CLAUDE.local.md

# Agent instruction files are rendered live by the SessionStart hook
# (.claude/hooks/agent-instructions.sh) from agent-context/sections, not
# committed. Preview with `nix build .#claude-md --print-out-paths | xargs cat`.
/AGENTS.md
/CLAUDE.md

# Skills are built into a nix-store link farm (the `skills` flake package) and
# symlinked here by the hook for Claude Code and Codex.
/.claude/skills
/.agents/

# macOS
.DS_Store

# Generated by nix (ix.buildSvelteSite) and embedded via dashboard-core/build.rs; never commit it.
packages/dashboard-core/src/dashboard/dashboard.html

# ix-mcp / jupyter-collaboration writes this YDoc store into the server cwd at runtime
.jupyter_ystore.db
*.ystore.db

# Stray command logs (e.g. a `cmd 2>err.log` that got swept up by `git add -A`)
*.log
