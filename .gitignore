# Nix
.jupyter/
.ipynb_checkpoints/
result
result-*
.direnv/

# ix CLI local state
.ix/

# Build outputs
.gradle/
# Anchored to the repo root: ignores a real top-level build-output dir without
# shadowing the tracked source dir lib/build/ (issue #1146).
/build/
target/
target-*/
buck-out/
dist/

# Node / pnpm
node_modules/
.pnpm-store/

# SvelteKit / Vite
.svelte-kit/
.vite/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
*.egg-info/
# Compiled PyO3 extension modules dropped in-tree by `maturin develop`
*.abi3.so
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.basedpyright/

# Terraform / OpenTofu local state
.terraform/
*.tfstate
*.tfstate.*

# Local caches and scratch
.tmp/
.hegel/
.worktrees/

# Editors
.idea/

# Claude Code per-machine overrides
.claude/settings.local.json
CLAUDE.local.md

# Skills are built into the `skills` flake package (one dir per skills/<name>)
# and copied here by the SessionStart hook (.claude/hooks/agent-instructions.sh)
# for Claude Code and Codex. Preview with
# `nix build .#skills --print-out-paths | xargs ls`.
/.claude/skills
/.agents/

# Subagents are rendered into the `agents` flake package and copied here by the
# hook for Claude Code (Codex's subagents are config-driven, not files).
/.claude/agents

# macOS
.DS_Store

# Generated by nix (ix.buildSvelteSite) and embedded via dashboard-core/build.rs; never commit it.
packages/dashboard/dashboard-core/src/dashboard/dashboard.html

# ix-mcp / jupyter-collaboration writes this YDoc store into the server cwd at runtime
.jupyter_ystore.db
*.ystore.db

# Stray command logs (e.g. a `cmd 2>err.log` that got swept up by `git add -A`)
*.log
