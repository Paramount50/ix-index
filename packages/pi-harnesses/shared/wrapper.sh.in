#!/usr/bin/env bash
# Generated by mk-pi-harness.nix. Wraps `pi` with a fixed posture and a
# declarative model table. Unlike the engine harness, the new harnesses keep
# the built-in tools PRESENT - the executor needs to do real work and the
# child agents (prosecutor / beam branches) need to probe ground truth.
set -euo pipefail

export PATH="@PATH@:${PATH:-}"
@EXT_ENV@

# Directory holding the bundled extensions, relative to this wrapper.
here="$(cd "$(dirname "${BASH_SOURCE[0]}")/../share/@NAME@" && pwd)"

# Resolve the model alias (PI_HARNESS_MODEL, default @DEFAULT_MODEL@) to a
# provider/model pair from models.nix. Exported so child `pi` invocations and
# extensions can reuse the active model.
PI_PROVIDER=""
PI_MODEL=""
PI_THINKING=""
case "${PI_HARNESS_MODEL:-@DEFAULT_MODEL@}" in
@MODEL_CASE@
  *)
    echo "@NAME@: unknown PI_HARNESS_MODEL '${PI_HARNESS_MODEL:-@DEFAULT_MODEL@}'" >&2
    exit 2
    ;;
esac
export PI_PROVIDER PI_MODEL PI_THINKING

extflags=()
for ext in @EXT_BASENAMES@; do
  extflags+=( -e "$here/$ext" )
done

thinkflag=()
[ -n "$PI_THINKING" ] && thinkflag=( --thinking "$PI_THINKING" )

exec @PI@ @FLAGS@ --provider "$PI_PROVIDER" --model "$PI_MODEL" "${thinkflag[@]}" "${extflags[@]}" "$@"
