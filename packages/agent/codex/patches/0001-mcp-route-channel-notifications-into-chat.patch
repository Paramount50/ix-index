+    pub(crate) fn make_notification_sender(&self, server_name: String) -> SendNotification {
+        let handler = self.notification_handler.clone();
+        Box::new(move |notification| {
+            let handler = handler.clone();
+            let server_name = server_name.clone();
+            async move {
+                handle_custom_notification(server_name, handler, notification).await;
+                Ok(())
+            }
+            .boxed()
+        })
+    }
+}
+
+async fn handle_custom_notification(
+    server_name: String,
+    handler: Option<McpNotificationHandlerHandle>,
+    notification: CustomNotification,
+) {
+    if !matches!(
+        notification.method.as_str(),
+        CLAUDE_CHANNEL_NOTIFICATION_METHOD | CODEX_CHANNEL_NOTIFICATION_METHOD
+    ) {
+        return;
+    }
+    let Some(handler) = handler else {
+        return;
+    };
+    let method = notification.method.clone();
+    let params = match notification.params_as::<ChannelNotificationParams>() {
+        Ok(Some(params)) => params,
+        Ok(None) => {
+            warn!("MCP channel notification from {server_name} missing params");
+            return;
+        }
+        Err(error) => {
+            warn!("MCP channel notification from {server_name} has invalid params: {error}");
+            return;
+        }
+    };
+    if let Err(error) = handler
+        .handle(McpChannelNotification {
+            server_name: server_name.clone(),
+            method,
+            content: params.content,
+            meta: params.meta,
+        })
+        .await
+    {
+        warn!("MCP channel notification handler failed for {server_name}: {error}");
+    }
 }
 
