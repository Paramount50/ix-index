+impl McpNotificationHandler for ChannelMcpNotificationHandler {
+    fn handle(
+        &self,
+        notification: McpChannelNotification,
+    ) -> BoxFuture<'static, anyhow::Result<()>> {
+        let session = self.session.clone();
+        Box::pin(async move {
+            let Some(session) = session.upgrade() else {
+                return Ok(());
+            };
+            let text = format_mcp_channel_notification(notification)?;
+            user_input_or_turn(
+                &session,
+                new_submission_id(),
+                Op::UserInput {
+                    items: vec![UserInput::Text {
+                        text,
+                        text_elements: Vec::new(),
+                    }],
+                    final_output_json_schema: None,
+                    responsesapi_client_metadata: None,
+                    additional_context: Default::default(),
+                    thread_settings: Default::default(),
+                },
+                None,
+            )
+            .await;
+            Ok(())
+        })
+    }
+}
+
+fn format_mcp_channel_notification(
+    notification: McpChannelNotification,
+) -> anyhow::Result<String> {
+    let mut attributes = vec![format!(
+        "source=\"{}\"",
+        xml_escape_attribute(&notification.server_name)
+    )];
+    if notification.method != "notifications/claude/channel" {
+        attributes.push(format!(
+            "method=\"{}\"",
+            xml_escape_attribute(&notification.method)
+        ));
+    }
+    if let Some(serde_json::Value::Object(meta)) = notification.meta {
+        let mut meta = meta.into_iter().collect::<Vec<_>>();
+        meta.sort_by(|(left, _), (right, _)| left.cmp(right));
+        for (key, value) in meta {
+            let value = match value {
+                serde_json::Value::String(value) => value,
+                value => serde_json::to_string(&value)?,
+            };
+            attributes.push(format!(
+                "{}=\"{}\"",
+                xml_escape_attribute(&key),
+                xml_escape_attribute(&value)
+            ));
+        }
+    }
+    Ok(format!(
+        "<channel {}>{}</channel>",
+        attributes.join(" "),
+        xml_escape_text(&notification.content)
+    ))
+}
+
+fn xml_escape_text(value: &str) -> String {
+    value
+        .replace('&', "&amp;")
+        .replace('<', "&lt;")
+        .replace('>', "&gt;")
+}
+
+fn xml_escape_attribute(value: &str) -> String {
+    xml_escape_text(value)
+        .replace('"', "&quot;")
+        .replace('\'', "&apos;")
+}
