+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::sync::Mutex as StdMutex;
+
+    #[derive(Default)]
+    struct RecordingNotificationHandler {
+        notifications: Arc<StdMutex<Vec<McpChannelNotification>>>,
+    }
+
+    impl McpNotificationHandler for RecordingNotificationHandler {
+        fn handle(
+            &self,
+            notification: McpChannelNotification,
+        ) -> BoxFuture<'static, Result<()>> {
+            let notifications = Arc::clone(&self.notifications);
+            async move {
+                notifications
+                    .lock()
+                    .unwrap_or_else(std::sync::PoisonError::into_inner)
+                    .push(notification);
+                Ok(())
+            }
+            .boxed()
+        }
+    }
+
+    #[tokio::test]
+    async fn channel_notification_sender_routes_claude_channel_events() {
+        let handler = Arc::new(RecordingNotificationHandler::default());
+        let notifications = Arc::clone(&handler.notifications);
+        let manager = ElicitationRequestManager::new(
+            AskForApproval::Never,
+            PermissionProfile::default(),
+            None,
+            Some(handler),
+            ElicitationRequestRouter::default(),
+        );
+
+        let send = manager.make_notification_sender("ix".to_string());
+        send(CustomNotification::new(
+            "notifications/claude/channel",
+            Some(serde_json::json!({
+                "content": "build failed",
+                "meta": {"severity": "high", "run_id": 123}
+            })),
+        ))
+        .await
+        .unwrap();
+
+        assert_eq!(
+            notifications
+                .lock()
+                .unwrap_or_else(std::sync::PoisonError::into_inner)
+                .as_slice(),
+            &[McpChannelNotification {
+                server_name: "ix".to_string(),
+                method: "notifications/claude/channel".to_string(),
+                content: "build failed".to_string(),
+                meta: Some(serde_json::json!({"severity": "high", "run_id": 123})),
+            }]
+        );
+    }
+
+    #[tokio::test]
+    async fn channel_notification_sender_ignores_other_custom_events() {
+        let handler = Arc::new(RecordingNotificationHandler::default());
+        let notifications = Arc::clone(&handler.notifications);
+        let manager = ElicitationRequestManager::new(
+            AskForApproval::Never,
+            PermissionProfile::default(),
+            None,
+            Some(handler),
+            ElicitationRequestRouter::default(),
+        );
+
+        let send = manager.make_notification_sender("ix".to_string());
+        send(CustomNotification::new(
+            "notifications/other",
+            Some(serde_json::json!({"content": "ignored"})),
+        ))
+        .await
+        .unwrap();
+
+        assert!(
+            notifications
+                .lock()
+                .unwrap_or_else(std::sync::PoisonError::into_inner)
+                .is_empty()
+        );
+    }
+}
