From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@indexable.ai>
Date: Tue, 7 Jul 2026 19:43:20 -0700
Subject: [PATCH] Add xattrs column to ls -l

Expose extended attribute names in the long listing output as an `xattrs`
column on Unix platforms. This lets Nushell users inspect filesystem metadata
that native `ls -l` marks with `@` and addresses the xattr side of #7106.

The column is empty when the filesystem reports no readable attributes, so the
existing table shape stays stable for scripts.

diff --git a/Cargo.lock b/Cargo.lock
index a10817e..1c06e74 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -4668,6 +4668,7 @@ dependencies = [
  "win_uds",
  "windows 0.62.2",
  "winreg",
+ "xattr",
 ]
 
 [[package]]
diff --git a/Cargo.toml b/Cargo.toml
index 350d348..7c76e42 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -281,6 +281,7 @@ uuid = "1.23.1"
 v_htmlescape = "0.15.8"
 memchr = "2.8.0"
 wax = "0.7.0"
+xattr = "1.6.1"
