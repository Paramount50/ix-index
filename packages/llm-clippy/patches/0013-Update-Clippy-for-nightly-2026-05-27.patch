From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Andrew Gazelka <andrew.gazelka@gmail.com>
Date: Wed, 27 May 2026 09:50:56 -0700
Subject: [PATCH] Update Clippy for nightly 2026-05-27


diff --git a/clippy_lints/src/duplicate_mod.rs b/clippy_lints/src/duplicate_mod.rs
index cb3cb2479..35b20b074 100644
--- a/clippy_lints/src/duplicate_mod.rs
+++ b/clippy_lints/src/duplicate_mod.rs
@@ -3,6 +3,7 @@ use rustc_ast::ast::{Crate, Inline, Item, ItemKind, ModKind};
 use rustc_errors::MultiSpan;
 use rustc_lint::{EarlyContext, EarlyLintPass, Level, LintContext};
 use rustc_middle::lint::LevelSpec;
+use rustc_session::lint::UnstableLintExpectationId;
 use rustc_session::impl_lint_pass;
 use rustc_span::{FileName, Span};
 use std::collections::BTreeMap;
@@ -51,7 +52,7 @@ impl_lint_pass!(DuplicateMod => [DUPLICATE_MOD]);
 struct Modules {
     local_path: PathBuf,
     spans: Vec<Span>,
-    lint_level_specs: Vec<LevelSpec>,
+    lint_level_specs: Vec<LevelSpec<UnstableLintExpectationId>>,
 }
 
 #[derive(Default)]
diff --git a/clippy_utils/src/sym.rs b/clippy_utils/src/sym.rs
index 6a7637fb1..492eb8970 100644
--- a/clippy_utils/src/sym.rs
+++ b/clippy_utils/src/sym.rs
@@ -202,6 +202,7 @@ generate! {
     cx,
     cycle,
     cyclomatic_complexity,
+    dbg_macro,
     de,
     debug_struct,
     deprecated_in_future,
diff --git a/rust-toolchain.toml b/rust-toolchain.toml
index 203f5981b..524cb7f62 100644
--- a/rust-toolchain.toml
+++ b/rust-toolchain.toml
@@ -1,6 +1,6 @@
 [toolchain]
 # begin autogenerated nightly
-channel = "nightly-2026-05-17"
+channel = "nightly-2026-05-27"
 # end autogenerated nightly
 components = ["cargo", "llvm-tools", "rust-src", "rust-std", "rustc", "rustc-dev", "rustfmt"]
 profile = "minimal"
