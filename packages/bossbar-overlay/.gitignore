# Rust build output
/app/target

# Vanilla Minecraft boss bar textures are Mojang's art; we do not redistribute
# them. `app/scripts/fetch-assets.sh` downloads them locally and the Nix build
# fetches them at build time. See app/scripts/fetch-assets.sh.
/app/assets/boss_bar/

# The Minecraft title TTF (tryashtar/minecraft-ttf) is Mojang-derived art and is
# not redistributed here; it is fetched into app/assets/fonts/ the same way.
/app/assets/fonts/

