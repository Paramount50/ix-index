 				"\"pid\", \"program\", \"arguments\", \"threads\",",
-				"\"user\", \"memory\", \"cpu lazy\" and",
+				"\"user\", \"memory\", \"io read\", \"io write\",",
+				"\"io total\", \"cpu lazy\" and",
