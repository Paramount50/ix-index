    async def startup_info(self) -> StartupInfo | None: ...
    async def fork(
        self, snapshot_id: str | None = ..., name: str | None = ...
    ) -> Branch: ...
    def fork_with_progress(
        self, snapshot_id: str, name: str | None = ...
    ) -> ForkProgressStream: ...
    async def migrate(self, target_node_id: str | None = ...) -> MigrationStart: ...
