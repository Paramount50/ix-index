"""Type stubs for the native PyO3 module.

Hand-maintained to mirror crates/ix/sdk-py/src/. Keep in sync when adding or
changing PyO3 bindings — pyright uses this file to type-check the wrapper
layer in __init__.py.

Methods that the wrapper does not call are intentionally omitted to keep the
stub small. Add them when needed.
"""
from __future__ import annotations

import enum
from collections.abc import AsyncIterator

__version__: str

