class Commit:
    """Snapshot of a VM, with metadata fields and branch/fork methods."""
    @property
    def id(self) -> str: ...
    @property
    def branch_id(self) -> str: ...
    @property
    def parent_id(self) -> str | None: ...
    @property
    def status(self) -> str: ...
    @property
    def memory_mib(self) -> int: ...
    @property
    def manifest_key(self) -> str | None: ...
    @property
    def created_at_millis(self) -> int: ...
    async def branch(self, name: str | None = ...) -> Branch: ...
    def branch_with_progress(self, name: str | None = ...) -> StartProgressStream: ...
    async def fork(self, name: str | None = ...) -> Branch: ...

# ── Streams ─────────────────────────────────────────────────────────

class ExecOutputStream(AsyncIterator[ExecChunk]):
    @property
    def exit_code(self) -> int | None: ...
    def __aiter__(self) -> ExecOutputStream: ...
    async def __anext__(self) -> ExecChunk: ...

class LogOutputStream(AsyncIterator[bytes]):
    def __aiter__(self) -> LogOutputStream: ...
    async def __anext__(self) -> bytes: ...

class CreateProgressStream(AsyncIterator["ProgressEvent | Branch"]):
    def __aiter__(self) -> CreateProgressStream: ...
    async def __anext__(self) -> ProgressEvent | Branch: ...

class StartProgressStream(AsyncIterator["ProgressEvent | Branch"]):
    def __aiter__(self) -> StartProgressStream: ...
    async def __anext__(self) -> ProgressEvent | Branch: ...

class ForkProgressStream(AsyncIterator["ProgressEvent | Branch"]):
    def __aiter__(self) -> ForkProgressStream: ...
    async def __anext__(self) -> ProgressEvent | Branch: ...

class VmStatusStream(AsyncIterator[VmStatusEvent]):
    def __aiter__(self) -> VmStatusStream: ...
    async def __anext__(self) -> VmStatusEvent: ...

class StreamConnection:
    async def read(self, n: int) -> bytes: ...
    async def write(self, data: bytes) -> int: ...
    async def close(self) -> None: ...

