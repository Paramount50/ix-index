    def subscribe_status(self) -> VmStatusStream: ...
    async def exec(
        self, command: list[str], working_dir: str | None = ...
    ) -> ExecResult: ...
    async def exec_checked(
        self, command: list[str], working_dir: str | None = ...
    ) -> ExecResult: ...
    def exec_stream(
        self, command: list[str], working_dir: str | None = ...
    ) -> ExecOutputStream: ...
    async def bash(
        self, script: str, working_dir: str | None = ...
    ) -> ExecResult: ...
    async def bash_checked(
        self, script: str, working_dir: str | None = ...
    ) -> ExecResult: ...
    def bash_stream(
        self, script: str, working_dir: str | None = ...
    ) -> ExecOutputStream: ...
    async def spawn(
        self, command: list[str], working_dir: str | None = ...
    ) -> int: ...
    async def log(self) -> list[Commit]: ...
    def fs(self) -> FsHandle: ...
    def secrets(self) -> SecretsHandle: ...
    def logs_stream(self, stream: str = ...) -> LogOutputStream: ...
    async def logs(
        self, stream: str, limit: int, since: int | None = ...
    ) -> list[LogEntry]: ...

