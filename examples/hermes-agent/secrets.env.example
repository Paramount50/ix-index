# Example secrets file for the Hermes operator VM.
#
# Copy this file to /run/secrets/hermes.env on the running VM with
# mode 0400 and owner hermes:hermes. The systemd unit reads it via
# `EnvironmentFile=` and never writes it to /nix/store.
#
# Smallest working setup: uncomment OPENROUTER_API_KEY and put one key.
# Then `systemctl restart hermes-agent` and `hermes chat`.
#
# Every other section is independent. Enable a feature in the fleet
# preset (`_module.args.hermes.<feature> = true`), drop the matching
# credentials here, restart.

# --- Model provider (required) ------------------------------------
# OpenRouter routes one key to every hosted model. Swap base_url
# and key name for Anthropic or OpenAI direct.
OPENROUTER_API_KEY=sk-or-...

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# --- Telegram (hermes.telegram = true) ----------------------------
# Bot token from @BotFather. ALLOWED_USERS is a CSV of Telegram user
# IDs the bot will accept messages from. Long-poll, no inbound port.
# TELEGRAM_BOT_TOKEN=123456789:ABC...
# TELEGRAM_ALLOWED_USERS=123456789

# --- Discord (hermes.discord = true) ------------------------------
# Bot token from the Discord Developer Portal. Connects via the
# Discord WebSocket gateway, no inbound port needed.
# DISCORD_BOT_TOKEN=...

# --- Web search (hermes.webSearch = "tavily" | "exa" | ...) -------
# One key per chosen backend. Picks the right env var by name.
# TAVILY_API_KEY=tvly-...
# EXA_API_KEY=...
# FIRECRAWL_API_KEY=fc-...
# PARALLEL_API_KEY=...

# --- Text-to-speech (hermes.tts = "elevenlabs" | ...) -------------
# Edge TTS (the default) is free and needs nothing here.
# ELEVENLABS_API_KEY=...
# MINIMAX_API_KEY=...
# VOICE_TOOLS_OPENAI_KEY=sk-...

# --- Image generation (hermes.imageGen = true) --------------------
# FAL.ai routes FLUX 2, Ideogram V3, Recraft V4, and others.
# FAL_KEY=...

# --- Memory provider (hermes.memory = "mem0" | "supermemory" | ...)
# Holographic (the default) is local SQLite and needs nothing here.
# MEM0_API_KEY=...
# SUPERMEMORY_API_KEY=...
# HONCHO_API_KEY=...
# HINDSIGHT_API_KEY=...

# --- Home Assistant (hermes.homeAssistant = true) -----------------
# Long-lived access token from a HASS user profile. HASS_URL points
# at your reachable HASS instance.
# HASS_TOKEN=...
# HASS_URL=http://homeassistant.local:8123
